{
  "name": "@drama/plm-ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Drama PLM React UI surface",
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./PlotPilotNativePage": {
      "types": "./dist/types/PlotPilotNativePage.d.ts",
      "import": "./dist/esm/PlotPilotNativePage.js",
      "default": "./dist/esm/PlotPilotNativePage.js"
    },
    "./PlotPilotNativeContainer": {
      "types": "./dist/types/PlotPilotNativeContainer.d.ts",
      "import": "./dist/esm/PlotPilotNativeContainer.js",
      "default": "./dist/esm/PlotPilotNativeContainer.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "package.json"],
  "scripts": {
    "build": "bun run ../../scripts/build-drama-package.ts .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@drama/core": "workspace:*",
    "@drama/graph": "workspace:*",
    "@drama/plm": "workspace:*",
    "@drama/ui": "workspace:*",
    "lucide-react": "^0.561.0",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.9.3"
  }
}
